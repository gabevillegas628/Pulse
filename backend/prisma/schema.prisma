generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Professor {
  id           String    @id @default(cuid())
  email        String    @unique
  passwordHash String
  name         String
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt
  classes      Class[]
}

model Student {
  id           String              @id @default(cuid())
  netId        String              @unique
  email        String              @unique
  passwordHash String
  createdAt    DateTime            @default(now())
  updatedAt    DateTime            @updatedAt
  enrollments  Enrollment[]
  responses    Response[]
  extensions   DeadlineExtension[]
}

model Class {
  id             String        @id @default(cuid())
  professorId    String
  professor      Professor     @relation(fields: [professorId], references: [id], onDelete: Cascade)
  name           String
  description    String?
  joinCode       String        @unique
  textbookRepo   String?
  textbookPath   String?
  textbookBranch String?
  createdAt      DateTime      @default(now())
  updatedAt      DateTime      @updatedAt
  sessions       Session[]
  assignments    Assignment[]
  enrollments    Enrollment[]
  sections       Section[]
  textbookViews  TextbookView[]
}

model TextbookView {
  id              String   @id @default(cuid())
  classId         String
  class           Class    @relation(fields: [classId], references: [id], onDelete: Cascade)
  chapterFilename String
  viewedAt        DateTime @default(now())

  @@index([classId])
  @@index([classId, chapterFilename])
}

model Section {
  id          String       @id @default(cuid())
  classId     String
  class       Class        @relation(fields: [classId], references: [id], onDelete: Cascade)
  name        String
  joinCode    String       @unique
  createdAt   DateTime     @default(now())
  enrollments Enrollment[]
  runs        SessionRun[]
}

model Enrollment {
  studentId  String
  classId    String
  sectionId  String?
  student    Student  @relation(fields: [studentId], references: [id], onDelete: Cascade)
  class      Class    @relation(fields: [classId], references: [id], onDelete: Cascade)
  section    Section? @relation(fields: [sectionId], references: [id])
  enrolledAt DateTime @default(now())

  @@id([studentId, classId])
}

// ─── IN_CLASS ─────────────────────────────────────────────────────────────────

model Session {
  id         String          @id @default(cuid())
  classId    String
  class      Class           @relation(fields: [classId], references: [id], onDelete: Cascade)
  title      String
  accessCode String          @unique
  status     SessionStatus   @default(DRAFT)
  createdAt  DateTime        @default(now())
  updatedAt  DateTime        @updatedAt
  questions  Question[]
  groups     QuestionGroup[]
  runs       SessionRun[]
}

model SessionRun {
  id        String        @id @default(cuid())
  sessionId String
  session   Session       @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  sectionId String?
  section   Section?      @relation(fields: [sectionId], references: [id])
  status    SessionStatus @default(OPEN)
  openedAt  DateTime      @default(now())
  closedAt  DateTime?
  createdAt DateTime      @default(now())
  responses Response[]

  @@index([sessionId])
  @@index([sectionId])
}

// ─── HOMEWORK ─────────────────────────────────────────────────────────────────

model Assignment {
  id         String              @id @default(cuid())
  classId    String
  class      Class               @relation(fields: [classId], references: [id], onDelete: Cascade)
  title      String
  status     SessionStatus       @default(OPEN)
  deadline   DateTime?
  createdAt  DateTime            @default(now())
  updatedAt  DateTime            @updatedAt
  questions  Question[]
  groups     QuestionGroup[]
  extensions DeadlineExtension[]
}

model DeadlineExtension {
  id           String     @id @default(cuid())
  assignmentId String
  studentId    String
  deadline     DateTime
  createdAt    DateTime   @default(now())
  assignment   Assignment @relation(fields: [assignmentId], references: [id], onDelete: Cascade)
  student      Student    @relation(fields: [studentId], references: [id], onDelete: Cascade)

  @@unique([assignmentId, studentId])
  @@index([assignmentId])
}

model QuestionGroup {
  id           String      @id @default(cuid())
  sessionId    String?
  session      Session?    @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  assignmentId String?
  assignment   Assignment? @relation(fields: [assignmentId], references: [id], onDelete: Cascade)
  title        String
  text         String?
  order        Int
  createdAt    DateTime    @default(now())
  questions    Question[]

  @@index([sessionId])
  @@index([assignmentId])
}

// ─── Shared ───────────────────────────────────────────────────────────────────

enum SessionStatus {
  DRAFT
  OPEN
  CLOSED
  ARCHIVED
}

enum QuestionType {
  FREE_TEXT
  MULTIPLE_CHOICE
  RATING
  YES_NO
  NUMERIC
  MULTI_SELECT
  ORDERING
  STRUCTURE
}

model Question {
  id            String          @id @default(cuid())
  sessionId     String?
  session       Session?        @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  assignmentId  String?
  assignment    Assignment?     @relation(fields: [assignmentId], references: [id], onDelete: Cascade)
  groupId       String?
  group         QuestionGroup?  @relation(fields: [groupId], references: [id])
  text          String
  type          QuestionType    @default(FREE_TEXT)
  options       Json?
  order         Int
  accessCode    String          @unique
  correctAnswer String?
  tolerance     Float?
  unit          String?
  responses     Response[]

  @@index([sessionId])
  @@index([assignmentId])
  @@index([groupId])
}

model Response {
  id           String      @id @default(cuid())
  questionId   String
  studentId    String
  runId        String?
  question     Question    @relation(fields: [questionId], references: [id], onDelete: Cascade)
  student      Student     @relation(fields: [studentId], references: [id], onDelete: Cascade)
  run          SessionRun? @relation(fields: [runId], references: [id])
  responseText String
  wordCount    Int
  isFlagged    Boolean     @default(false)
  aiScore      Float?
  isDraft      Boolean     @default(true)
  submittedAt  DateTime    @default(now())

  @@unique([questionId, studentId])
  @@index([questionId])
  @@index([runId])
  @@index([studentId])
}
